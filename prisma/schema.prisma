generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
}

model Settings {
  id               String   @id @default("default")
  metaAccessToken  String?
  anthropicApiKey  String?
  auditPrompt      String?  @default("Você é um especialista em tráfego pago. Analise os seguintes dados do Meta Ads e gere um plano de ação priorizado.")
  
  targetCpl        Float    @default(0)
  selectedColumns  String   @default("results,cost_per_result,spend,impressions,ctr_link,cpl")

  // Audit Thresholds
  maxCpl           Float    @default(80)
  maxFrequency     Float    @default(3.5)
  minCtr           Float    @default(0.5)

  updatedAt        DateTime @updatedAt
}

model AuditHistory {
  id          String   @id @default(cuid())
  accountId   String
  accountName String
  data        String   // JSON stringified audit data
  report      String   // AI generated report
  createdAt   DateTime @default(now())
}
